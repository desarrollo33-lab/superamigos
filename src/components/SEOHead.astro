---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, canonical, ogImage, ogType } = Astro.props;
const siteUrl = "https://superamigos.cl";
const ogImageDefault = `${siteUrl}/og-image.png`;
---

<title>{title}</title>
<meta name="description" content={description} />
{canonical && <link rel="canonical" href={canonical} />}

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType || "website"} />
<meta property="og:url" content={canonical || siteUrl} />
<meta property="og:image" content={ogImage || ogImageDefault} />
<meta property="og:locale" content="es_CL" />
<meta property="og:site_name" content="Superamigos - Jardinero Las Condes" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage || ogImageDefault} />
