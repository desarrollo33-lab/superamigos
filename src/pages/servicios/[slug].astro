---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services } from "../../data/site";

export function getStaticPaths() {
  return services.map((svc) => ({
    params: { slug: svc.slug },
    props: { service: svc },
  }));
}

const { service } = Astro.props;
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-700 to-green-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-green-200 text-sm mb-6">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/servicios" class="hover:text-white no-underline">Servicios</a>
        <span class="mx-2">/</span>
        <span class="text-white">{service.name}</span>
      </nav>
      <h1 class="font-heading text-4xl lg:text-5xl font-bold mb-4">
        {service.name}
      </h1>
      <p class="text-green-100 text-lg max-w-2xl">{service.description}</p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main -->
        <div class="lg:col-span-2 space-y-12">
          <!-- Features -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">
              ¿Qué incluye este servicio?
            </h2>
            <ul class="space-y-3">
              {
                service.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <div class="w-5 h-5 rounded-full bg-green-100 flex items-center justify-center mt-0.5 shrink-0">
                      <svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-700">{feature}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Process -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">
              Nuestro proceso
            </h2>
            <div class="space-y-6">
              {
                service.process.map((step, i) => (
                  <div class="flex gap-4">
                    <div class="shrink-0">
                      <div class="w-10 h-10 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">
                        {i + 1}
                      </div>
                    </div>
                    <div>
                      <h3 class="font-heading font-semibold text-gray-900 mb-1">
                        {step.step}
                      </h3>
                      <p class="text-gray-600 text-sm leading-relaxed">
                        {step.description}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- FAQ -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">
              Preguntas frecuentes
            </h2>
            <div class="space-y-2">
              {
                service.faqs.map((faq) => (
                  <details class="faq-item bg-white rounded-xl border border-gray-200 px-5">
                    <summary>{faq.question}</summary>
                    <p>{faq.answer}</p>
                  </details>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-green-50 rounded-2xl p-6 sticky top-24 border border-green-100">
            <h3 class="font-heading font-bold text-lg text-gray-900 mb-4">
              Solicitar presupuesto
            </h3>
            <div class="space-y-4 mb-6">
              <div>
                <p class="text-sm text-gray-500">Precio desde</p>
                <p class="text-2xl font-bold text-green-700">{service.priceRange}</p>
              </div>
            </div>
            <a
              href="https://wa.me/56999999999"
              target="_blank"
              class="w-full inline-flex items-center justify-center gap-2 bg-green-600 text-white font-semibold px-5 py-3 rounded-xl hover:bg-green-700 transition-colors no-underline text-center"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp gratis
            </a>
            <p class="text-xs text-gray-500 text-center mt-3">
              Respuesta en menos de 2 horas
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- More zones CTA -->
  <section class="py-12 bg-green-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-600 mb-4">
        Este servicio está disponible en todas nuestras zonas:
      </p>
      <div class="flex flex-wrap justify-center gap-2">
        {
          [
            "San Carlos de Apoquindo",
            "Los Dominicos",
            "Avenida Apoquindo",
            "La Quebrada",
            "Padre Hurtado",
          ].map((zone) => (
            <span class="bg-white border border-gray-200 text-gray-700 text-sm px-3 py-1.5 rounded-full">
              {zone}
            </span>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
