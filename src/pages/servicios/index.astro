---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services } from "../../data/site";
---

<BaseLayout
  title="Servicios de Jardinería en Las Condes | Superamigos"
  description="Servicios de jardinería en Las Condes: mantenimiento de jardines, corte de césped, poda de árboles, riego automático, plan mensual y recuperación de jardines. Jardinero profesional en San Carlos de Apoquindo y Los Dominicos."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-700 to-green-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-green-200 text-sm mb-6">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">Servicios</span>
      </nav>
      <h1 class="font-heading text-4xl lg:text-5xl font-bold mb-4">
        Servicios de Jardinería en Las Condes
      </h1>
      <p class="text-green-100 text-lg max-w-2xl">
        Todo lo que tu jardín necesita. Servicios profesionales en San Carlos de
        Apoquindo, Los Dominicos y todo el sector oriente.
      </p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          services.map((svc, i) => (
            <a
              href={`/servicios/${svc.slug}`}
              class="service-card block bg-white border border-gray-200 rounded-2xl p-6 no-underline"
            >
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
                <svg
                  class="w-6 h-6 text-green-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                  />
                </svg>
              </div>
              <h2 class="font-heading font-bold text-xl text-gray-900 mb-2">
                {svc.name}
              </h2>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">
                {svc.description.split(".")[0]}.
              </p>
              <ul class="space-y-1 mb-4">
                {svc.features.slice(0, 3).map((f) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg
                      class="w-4 h-4 text-green-500 mt-0.5 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-green-700 font-semibold text-sm">
                  {svc.priceRange}
                </span>
                <span class="text-green-600 text-sm font-medium flex items-center gap-1">
                  Ver más
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-green-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold text-gray-900 mb-4">
        ¿No sabes qué servicio necesitas?
      </h2>
      <p class="text-gray-500 mb-6">
        Escríbenos por WhatsApp y te asesoramos gratis. Te escuchamos y te
        recomendamos lo que tu jardín realmente necesita.
      </p>
      <a
        href="https://wa.me/56999999999?text=Hola!%20No%20estoy%20seguro%20de%20que%20servicio%20necesito.%20Pueden%20asesorarme?"
        target="_blank"
        class="btn-primary text-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        Asesorarme por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>
