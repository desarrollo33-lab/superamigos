---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { zones, services } from "../../../data/site";

// Generate ALL combinations of zone x service = 42 pages
export function getStaticPaths() {
  const paths = [];
  for (const zone of zones) {
    for (const service of services) {
      paths.push({
        params: { zona: zone.slug, servicio: service.slug },
        props: { zone, service },
      });
    }
  }
  return paths;
}

const { zone, service } = Astro.props;

// Personalize text with zone name
const heroHeading = service.heroHeading.replace("{zoneName}", zone.name);
const metaDesc = service.metaDescription.replace("{zoneName}", zone.name);
const descSvc = service.description.replace("{zoneName}", zone.name);

const title = `${service.name} en ${zone.name} | Superamigos`;
const description = `${descSvc} Especialista en ${zone.name}. Atención semanal y mensual. Solicita presupuesto por WhatsApp.`;
---

<BaseLayout
  title={title}
  description={description}
>
  <!-- Breadcrumb + Hero -->
  <section class="bg-gradient-to-br from-green-700 to-green-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-green-200 text-sm mb-6 flex items-center gap-2 text-xs">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span>/</span>
        <a href="/zonas" class="hover:text-white no-underline">Zonas</a>
        <span>/</span>
        <a href={`/zonas/${zone.slug}`} class="hover:text-white no-underline">{zone.name}</a>
        <span>/</span>
        <span class="text-white truncate max-w-[200px]">{service.name}</span>
      </nav>

      <div class="flex items-start gap-4">
        <div class="w-14 h-14 bg-green-600 rounded-2xl flex items-center justify-center shrink-0">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div>
          <div class="inline-flex items-center gap-2 bg-white/15 rounded-full px-3 py-1 mb-3">
            <span class="text-green-200 text-xs font-medium">{zone.name}</span>
          </div>
          <h1 class="font-heading text-3xl lg:text-4xl font-bold mb-2">
            {service.name} en {zone.name}
          </h1>
          <p class="text-green-100 text-base max-w-xl">{descSvc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Zone coverage -->
  <section class="bg-green-50 border-b border-green-100 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs text-gray-500 font-medium">Cobertura en {zone.name}:</span>
        {zone.nearbyStreets.map((s) => (
          <span class="bg-white border border-green-200 text-green-800 text-xs px-2 py-0.5 rounded-full">
            {s}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">

        <!-- Left: Content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Features -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">
              ¿Qué incluye el {service.name.toLowerCase()} en {zone.name}?
            </h2>
            <ul class="space-y-3">
              {service.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-green-100 flex items-center justify-center mt-0.5 shrink-0">
                    <svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-gray-700">{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Process -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">
              Cómo funciona nuestro servicio en {zone.name}
            </h2>
            <div class="space-y-6">
              {service.process.map((step, i) => (
                <div class="flex gap-4">
                  <div class="shrink-0">
                    <div class="w-10 h-10 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">
                      {i + 1}
                    </div>
                  </div>
                  <div>
                    <h3 class="font-heading font-semibold text-gray-900 mb-1">{step.step}</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">
              Preguntas frecuentes sobre {service.name.toLowerCase()} en {zone.name}
            </h2>
            <div class="space-y-2">
              {service.faqs.map((faq) => (
                <details class="faq-item bg-white rounded-xl border border-gray-200 px-5">
                  <summary>{faq.question}</summary>
                  <p>{faq.answer}</p>
                </details>
              ))}
            </div>
          </div>

          <!-- Zone context -->
          <div class="bg-green-50 rounded-2xl p-6 border border-green-100">
            <h3 class="font-heading font-bold text-gray-900 mb-3">
              Jardinería en {zone.name}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              {zone.description} Nuestros jardines en {zone.name} requieren mantenimiento
              regular para mantenerse saludables y estéticos durante todo el año.
              Conocemos las especies de plantas más comunes en {zone.name} y las
              mejores prácticas para su cuidado.
            </p>
          </div>
        </div>

        <!-- Sidebar: CTA -->
        <div>
          <div class="bg-green-600 rounded-2xl p-6 text-white sticky top-24">
            <h3 class="font-heading font-bold text-lg mb-2">
              Solicitar presupuesto
            </h3>
            <p class="text-green-100 text-sm mb-4">
              {service.name} en {zone.name}. Respuesta en menos de 2 horas.
            </p>
            <div class="mb-4">
              <p class="text-xs text-green-200 mb-1">Precio desde</p>
              <p class="text-2xl font-bold text-white">{service.priceRange}</p>
            </div>
            <a
              href={`https://wa.me/56999999999?text=Hola!%20Necesito%20${encodeURIComponent(service.name)}%20en%20${encodeURIComponent(zone.name)}.%20Pueden%20darme%20un%20presupuesto?`}
              target="_blank"
              class="w-full inline-flex items-center justify-center gap-2 bg-white text-green-700 font-bold px-5 py-3 rounded-xl hover:bg-green-50 transition-colors no-underline text-center mb-3"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp gratis
            </a>
            <p class="text-xs text-green-200 text-center">
              Sin compromiso · Sin costo
            </p>
          </div>

          <!-- Other services in this zone -->
          <div class="mt-6">
            <h4 class="font-heading font-semibold text-gray-900 text-sm mb-3">
              Otros servicios en {zone.name}
            </h4>
            <div class="space-y-2">
              {services.filter(s => s.slug !== service.slug).slice(0, 3).map((s) => (
                <a
                  href={`/zonas/${zone.slug}/${s.slug}`}
                  class="flex items-center justify-between bg-white border border-gray-200 rounded-xl px-4 py-3 no-underline hover:border-green-300 hover:bg-green-50 transition-colors"
                >
                  <span class="text-sm text-gray-700">{s.name}</span>
                  <svg class="w-4 h-4 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold text-gray-900 mb-4">
        Jardinero disponible en {zone.name}
      </h2>
      <p class="text-gray-500 mb-6">
        Contáctanos por WhatsApp y te cotizamos sin compromiso.
      </p>
      <a
        href={`https://wa.me/56999999999?text=Hola!%20Necesito%20${encodeURIComponent(service.name)}%20en%20${encodeURIComponent(zone.name)}`}
        target="_blank"
        class="btn-primary text-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        Solicitar presupuesto
      </a>
    </div>
  </section>
</BaseLayout>
