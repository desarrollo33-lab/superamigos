---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { zones, services } from "../../data/site";
---

<BaseLayout
  title="Jardinero en Las Condes | Zonas de Cobertura — Superamigos"
  description="Jardinero profesional en San Carlos de Apoquindo, Los Dominicos, Avenida Apoquindo, La Quebrada, Padre Hurtado y todo Las Condes oriente. Cobertura completa."
>
  <section class="bg-gradient-to-br from-green-700 to-green-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-green-200 text-sm mb-6">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">Zonas</span>
      </nav>
      <h1 class="font-heading text-4xl lg:text-5xl font-bold mb-4">
        Zonas de Cobertura
      </h1>
      <p class="text-green-100 text-lg max-w-2xl">
        Jardinero en San Carlos de Apoquindo, Los Dominicos y todo el sector
        oriente de Las Condes. Llegamos a tu barrio.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          zones.map((zone) => (
            <a
              href={`/zonas/${zone.slug}`}
              class="service-card block bg-white border border-gray-200 rounded-2xl p-6 no-underline"
            >
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <h2 class="font-heading font-bold text-lg text-gray-900">
                  {zone.name}
                </h2>
              </div>
              <p class="text-gray-500 text-sm mb-4">{zone.description.split(".")[0]}.</p>
              <div class="flex flex-wrap gap-1 mb-4">
                {zone.nearbyStreets.slice(0, 3).map((s) => (
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded-full">{s}</span>
                ))}
              </div>
              <span class="text-green-600 text-sm font-medium flex items-center gap-1">
                Ver servicios
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
