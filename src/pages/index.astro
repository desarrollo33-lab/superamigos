---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services, zones, siteConfig } from "../data/site";

const featuredServices = services.slice(0, 3);
---

<BaseLayout
  title="Superamigos | Jardinero en San Carlos de Apoquindo y Los Dominicos, Las Condes"
  description="Jardinero profesional en San Carlos de Apoquindo, Los Dominicos y Las Condes oriente. Mantenimiento de jardines, poda, corte de césped y riego automático. Presupuesto gratis por WhatsApp."
>
  <!-- Hero -->
  <section
    class="relative bg-gradient-to-br from-green-700 via-green-800 to-green-900 text-white overflow-hidden"
  >
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%">
        <pattern id="leaf" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
          <circle cx="30" cy="30" r="2" fill="white" />
          <circle cx="10" cy="10" r="1.5" fill="white" />
          <circle cx="50" cy="10" r="1.5" fill="white" />
          <circle cx="10" cy="50" r="1.5" fill="white" />
          <circle cx="50" cy="50" r="1.5" fill="white" />
        </pattern>
        <rect width="100%" height="100%" fill="url(#leaf)" />
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-3xl">
        <div
          class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6"
        >
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          <span class="text-green-100 text-sm font-medium"
            >San Carlos de Apoquindo y Los Dominicos</span
          >
        </div>

        <h1
          class="font-heading text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight mb-6"
        >
          Jardinero en<br />
          <span class="text-green-300">Las Condes</span>
        </h1>

        <p class="text-xl text-green-100 mb-8 max-w-2xl leading-relaxed">
          Mantenimiento de jardines, poda, corte de césped y riego automático en
          San Carlos de Apoquindo, Los Dominicos y todo el sector oriente.
          Profesional, puntual y con precios justos.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`https://wa.me/${siteConfig.whatsapp}?text=Hola!%20Necesito%20un%20jardinero%20en%20San%20Carlos%20de%20Apoquindo`}
            target="_blank"
            class="inline-flex items-center justify-center gap-2 bg-white text-green-800 font-bold px-6 py-4 rounded-xl hover:bg-green-50 transition-colors no-underline text-lg"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Presupuesto gratis
          </a>
          <a
            href="/servicios"
            class="inline-flex items-center justify-center gap-2 bg-green-600 text-white font-semibold px-6 py-4 rounded-xl border-2 border-white/30 hover:bg-green-500 transition-colors no-underline text-lg"
          >
            Ver servicios
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Zone badges -->
    <div class="relative bg-green-900/50 backdrop-blur-sm border-t border-green-700/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <p class="text-green-300 text-xs font-medium mb-3 uppercase tracking-wider">
          Zonas de cobertura
        </p>
        <div class="flex flex-wrap gap-2">
          {
            zones.map(
              (zone) =>
                zone && (
                  <a
                    href={`/zonas/${zone.slug}`}
                    class="bg-white/10 hover:bg-white/20 text-white text-xs font-medium px-3 py-1.5 rounded-full transition-colors no-underline"
                  >
                    {zone.name}
                  </a>
                )
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Trust badges -->
  <section class="bg-green-50 border-b border-green-100 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-stagger class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center">
          <div
            class="text-3xl font-bold text-green-700 font-heading">10+</div>
          <div class="text-sm text-gray-600 mt-1">Años de experiencia</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-700 font-heading">500+</div>
          <div class="text-sm text-gray-600 mt-1">Jardines mantenidos</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-700 font-heading">100%</div>
          <div class="text-sm text-gray-600 mt-1">Clientes satisfechos</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-700 font-heading">7</div>
          <div class="text-sm text-gray-600 mt-1">Días de trabajo</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-animate class="text-center mb-14">
        <h2 class="font-heading text-3xl lg:text-4xl font-bold text-gray-900">
          Servicios de jardinería
        </h2>
        <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
          Todo lo que tu jardín necesita, en un solo lugar. Servicios
          profesionales con atención personalizada.
        </p>
      </div>

      <div data-stagger class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          services.map((svc) => (
            <a
              href={`/servicios/${svc.slug}`}
              class="service-card block bg-white border border-gray-200 rounded-2xl p-6 no-underline"
            >
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
                <svg
                  class="w-6 h-6 text-green-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                  />
                </svg>
              </div>
              <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
                {svc.name}
              </h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">
                {svc.description.split(".")[0]}.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-green-700 font-semibold text-sm"
                  >{svc.priceRange}</span
                >
                <span class="text-green-600 text-sm font-medium flex items-center gap-1">
                  Conocer más
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>

      <div data-animate class="text-center mt-10">
        <a href="/servicios" class="btn-primary text-lg">
          Ver todos los servicios
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"
            />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Zones CTA -->
  <section class="py-20 bg-green-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        data-animate
        class="font-heading text-3xl lg:text-4xl font-bold text-white mb-4"
      >
        Cobertura en todo Las Condes oriente
      </h2>
      <p data-animate class="text-green-100 text-lg mb-10 max-w-2xl mx-auto">
        Llegamos a San Carlos de Apoquindo, Los Dominicos, Avenida Apoquindo, La
        Quebrada, Padre Hurtado y todo el sector oriente.
      </p>
      <div data-stagger class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-7 gap-3 max-w-4xl mx-auto">
        {
          zones.map(
            (zone) =>
              zone && (
                <a
                  href={`/zonas/${zone.slug}`}
                  class="bg-white/10 hover:bg-white/20 text-white text-sm font-medium px-3 py-2.5 rounded-xl transition-colors no-underline"
                >
                  {zone.name}
                </a>
              )
          )
        }
      </div>
      <div data-animate class="mt-10">
        <a
          href={`https://wa.me/${siteConfig.whatsapp}?text=Hola!%20Estoy%20en%20${zones[0]?.name}%20y%20necesito%20un%20jardinero`}
          target="_blank"
          class="inline-flex items-center gap-2 bg-white text-green-700 font-bold px-8 py-4 rounded-xl hover:bg-green-50 transition-colors no-underline text-lg"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Buscar en mi zona
        </a>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section id="nosotros" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-animate class="text-center mb-14">
        <h2 class="font-heading text-3xl lg:text-4xl font-bold text-gray-900">
          ¿Por qué elegir Superamigos?
        </h2>
        <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
          Somos jardinero de verdad, no una app. Conocemos Las Condes y sus
          barrios como la palma de la mano.
        </p>
      </div>

      <div data-stagger class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center">
          <div
            class="w-16 h-16 mx-auto bg-green-100 rounded-2xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
            Profesional y garantizado
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Si no estás satisfecho con el trabajo, lo repetimos sin costo. Así de
            simple.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 mx-auto bg-green-100 rounded-2xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
            Puntual y comprometido
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Si decimos que llegamos a las 9, llegamos a las 9. Respetamos tu
            tiempo.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 mx-auto bg-green-100 rounded-2xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
            WhatsApp directo
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Te atendemos por WhatsApp. Sin centrale, sin espera. Un jardinero
            real te responde.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 mx-auto bg-green-100 rounded-2xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
            Conocemos tu zona
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Operamos en San Carlos de Apoquindo, Los Dominicos y Las Condes
            oriente hace más de 10 años.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 mx-auto bg-green-100 rounded-2xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
            Precios justos
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Desde $15.000 por visita. Sin sorpresas. El presupuesto que te
            damos es el que pagas.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 mx-auto bg-green-100 rounded-2xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-8 h-8 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">
            Equipo completo
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Cortadoras, podadoras, bordeadoras, aspiradoras. Todo incluido, tú
            no tienes que preocuparte por nada.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        data-animate
        class="font-heading text-3xl lg:text-4xl font-bold text-gray-900 mb-4"
      >
        ¿Necesitas un jardinero en Las Condes?
      </h2>
      <p data-animate class="text-gray-500 text-lg mb-8">
        Escríbenos por WhatsApp y te respondemos en menos de 2 horas. Sin
        compromiso, presupuesto gratis.
      </p>
      <a
        data-animate
        href={`https://wa.me/${siteConfig.whatsapp}?text=Hola!%20Necesito%20un%20jardinero%20en%20Las%20Condes.%20Pueden%20darme%20un%20presupuesto?`}
        target="_blank"
        class="inline-flex items-center gap-2 bg-green-600 text-white font-bold px-8 py-4 rounded-xl hover:bg-green-700 transition-colors no-underline text-lg"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        Escribir por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>
